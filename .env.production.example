# Production environment variables — set these in your host's dashboard
# (Hostinger hPanel → your Node app → Environment Variables), NOT in a file.
#
# Values come from the hosted Supabase project:
#   Supabase dashboard → Project Settings → API

# Project URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://lhosfecnhiinrrmeegvz.supabase.co

# anon / publishable key (public — safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# service_role secret (SERVER ONLY — never expose to the browser).
# Copy from Supabase → Settings → API → "service_role" secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-here
